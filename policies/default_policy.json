{
  "version": "1.0",
  "name": "default_secure_vault_policy",

  "rules": {
    "data_storage": {
      "encryption_required": true,
      "allow_plaintext_storage": false,
      "chunking_enabled": true
    },

    "access_control": {
      "default_deny": true,
      "require_authentication": true,
      "session_timeout_seconds": 900
    },

    "sharing": {
      "default_share_level": "none",
      "allow_partial_disclosure": true,
      "require_explicit_user_consent": true
    },

    "logging": {
      "audit_all_access": true,
      "immutable_logs": true
    },

    "network": {
      "allow_remote_access": false,
      "allow_p2p_sync": false
    },

    "privacy": {
      "anonymization_enabled": true,
      "pii_redaction_enabled": true
    }
  }
}
